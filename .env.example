# Pippin / RavenX AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Anthropic (Claude — Iris's intelligence layer)
ANTHROPIC_API_KEY=sk-ant-...

# X / Twitter API (for @jolyneshibasol)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Solana / Helius RPC
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# RavenX Queue (path to approved posts JSONL)
RAVENX_QUEUE_PATH=/opt/ravenx/data/jolyne/approved_queue.jsonl
RAVENX_POSTED_LOG=/opt/ravenx/data/jolyne/posted_log.jsonl
